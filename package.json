{
  "name": "receipt-ai-scanner",
  "version": "1.1.0",
  "description": "Scan receipt images using vision-enabled LLMs with support for OpenAI, Anthropic, and OpenAI-compatible APIs",
  "author": "Sahil Jani <iam@janisahil.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sahiljani/receipt-ai-scanner.git"
  },
  "bugs": {
    "url": "https://github.com/sahiljani/receipt-ai-scanner/issues"
  },
  "homepage": "https://github.com/sahiljani/receipt-ai-scanner#readme",
  "sideEffects": false,
  "keywords": [
    "receipt",
    "ocr",
    "ai",
    "llm",
    "vision",
    "openai",
    "anthropic",
    "scanner"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.27.0",
    "openai": ">=4.52.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.84.0",
    "@types/node": "^25.5.2",
    "openai": "^6.33.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
